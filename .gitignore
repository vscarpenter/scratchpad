# Scratchpad — gitignore.
# This is a static-only app with no build step. Most ignores below are
# defensive (OS cruft, secrets, future tooling).

# ---- Secrets ----
# Never commit real env files. The .example file IS committed.
.env
.env.local
.env.*.local
!.env.local.example

# ---- OS / editor cruft ----
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
*~
*.swp
*.swo

# ---- Editor / IDE ----
.idea/
.vscode/
*.iml

# ---- Local agent/tooling artifacts ----
.claude/

# ---- Logs ----
*.log
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Dev tooling (Playwright) ----
# package.json + playwright.config.js ARE committed (test recipe).
# These directories are generated and never deployed.
node_modules/
dist/
build/
.cache/
playwright-report/
test-results/
blob-report/
.playwright-mcp/

# ---- Local verification artifacts ----
# Screenshots from local browser-driven verification. Not part of the app.
.verify/
