# Scratchpad deploy configuration.
# Copy this file to `.env.local` and fill in real values.
# `.env.local` must never be committed.

# Target S3 bucket (just the name, no s3:// prefix).
S3_BUCKET=scratchpad-prod-example

# CloudFront distribution ID to invalidate after each deploy.
CLOUDFRONT_DISTRIBUTION_ID=E1234567890ABC

# Optional. If unset, falls back to the default AWS profile / region from
# `aws configure` or the AWS_* env vars in your shell.
# AWS_PROFILE=scratchpad
# AWS_REGION=us-east-1
